# Copy this file to .env and fill in your values.
# Never commit .env to source control.

# ── Spotify OAuth2 credentials (required) ─────────────────────────────────────
# Get these from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=0734390a7e4440c09892f3d6c27eebd5
SPOTIFY_CLIENT_SECRET=f00a2d42d17c43548c0f19f55f23eaf3

# ── Deployment URLs (required in production, optional locally) ────────────────
# Public-facing URL of the Spring Boot backend.
# Must match the redirect URI registered in your Spotify Developer Dashboard.
#   Local:      http://127.0.0.1:8080
#   Production: https://api.your-domain.com
APP_BACKEND_URL=http://127.0.0.1:8080

# Public-facing URL of the React frontend.
# Used for post-login / post-logout redirects and CORS.
#   Local:      http://127.0.0.1:3000
#   Production: https://your-domain.com
APP_FRONTEND_URL=http://127.0.0.1:3000
